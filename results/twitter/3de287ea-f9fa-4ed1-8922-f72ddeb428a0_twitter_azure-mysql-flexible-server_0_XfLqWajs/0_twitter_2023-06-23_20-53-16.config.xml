<?xml version="1.0" encoding="UTF-8" standalone="no"?>
<configuration>
  <isolation>TRANSACTION_SERIALIZABLE</isolation>
  <batchsize>1024</batchsize>
  <scalefactor>5000.0</scalefactor>
  <tracefile>data/twitter/twitter_tweetids.txt</tracefile>
  <tracefile2>data/twitter/twitter_user_ids.txt</tracefile2>
  <base_ip>10.1.</base_ip>
  <terminals>125</terminals>
  <works>
    <work>
      <time>1800</time>
      <rate>unlimited</rate>
      <weights>1,1,7,90,1</weights>
    </work>
  </works>
  <transactiontypes>
    <transactiontype>
      <name>GetTweet</name>
    </transactiontype>
    <transactiontype>
      <name>GetTweetsFromFollowing</name>
    </transactiontype>
    <transactiontype>
      <name>GetFollowers</name>
    </transactiontype>
    <transactiontype>
      <name>GetUserTweets</name>
    </transactiontype>
    <transactiontype>
      <name>InsertTweet</name>
    </transactiontype>
  </transactiontypes>
  <loaderThreads>32</loaderThreads>
  <loaderThreads>32</loaderThreads>
</configuration>
